{
  "title": "Dota 2: Left Command to Option",
  "rules": [
    {
      "description": "Use the left Command key as Option in Dota 2",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_command",
            "modifiers": {
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "left_option"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.valvesoftware\\.dota2$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
