{
  "title": "System mouse back/forward",
  "rules": [
    {
      "description": "Map mouse button4/button5 to Back/Forward",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "pointing_button": "button4"
          },
          "to": [
            {
              "key_code": "open_bracket",
              "modifiers": ["left_command"]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "pointing_button": "button5"
          },
          "to": [
            {
              "key_code": "close_bracket",
              "modifiers": ["left_command"]
            }
          ]
        }
      ]
    }
  ]
}
