#!/usr/bin/env bash

# Kubernetes Debug Shell
# Creates a temporary toolbox pod for debugging and troubleshooting

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &> /dev/null && pwd)"
source "$SCRIPT_DIR/_helpers.sh"

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: $0"
    echo ""
    echo "Creates a temporary netshoot toolbox pod in a selected Kubernetes namespace"
    echo "Provides an interactive bash shell with common utilities for debugging"
    echo ""
    echo "Options:"
    echo "  -h, --help        Show this help message"
    echo ""
    echo "Prerequisites:"
    echo "  - kubectl must be installed and configured"
    echo "  - fzf must be installed for namespace selection"
    echo "  - Valid Kubernetes context and namespace access"
    echo ""
    echo "Examples:"
    echo "  $0                # Create netshoot pod in selected namespace"
    echo ""
    echo "The script will:"
    echo "  1. Select a namespace"
    echo "  2. Create a temporary netshoot pod"
    echo "  3. Open an interactive bash shell with utilities (curl, wget, etc.)"
    echo "  4. Automatically clean up the pod after exit"
    exit 0
fi

kube_require_cmd kubectl
kube_require_cmd fzf
kube_require_context

echo "Fetching namespaces..."
if ! namespace=$(kube_select_namespace); then
    exit 0
fi
pod_name=$(kube_unique_name "netshoot-debug")

echo "Running netshoot pod '$pod_name' in namespace '$namespace'"
kubectl run "$pod_name" --namespace="$namespace" --rm -i --tty --image=nicolaka/netshoot --restart=Never -- bash
